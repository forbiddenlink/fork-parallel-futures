# Fork — Parallel Futures: environment
#
# Copy this file to .env.local and fill in the real key. .env.local is
# gitignored. These vars are read ONLY in server-side route handlers
# (app/api/**) via lib/hermes.ts; they are never exposed to the browser.

# Your Hermes API key. Sent as: Authorization: Bearer <HERMES_API_KEY>
HERMES_API_KEY=

# Base URL of the running Hermes backend. Defaults to the local instance if
# unset. No trailing slash required.
HERMES_API_URL=http://127.0.0.1:8642
